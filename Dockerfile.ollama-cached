# Railway-optimized Dockerfile with pre-cached Ollama and Qwen model
FROM rust:1.82 as builder

WORKDIR /app
COPY . .
RUN cargo build --release --bin full-working-o1

# Ollama preparation stage
FROM ubuntu:22.04 as ollama-cache

# Install dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Start Ollama temporarily to download the model
RUN ollama serve & \
    sleep 5 && \
    ollama pull qwen2.5:1.5b && \
    pkill ollama && \
    sleep 2

# Compress the model files for faster transfer
RUN cd /root/.ollama && \
    tar -czf /ollama-models.tar.gz models/

# Final runtime stage
FROM ubuntu:22.04

# Install minimal dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama (binary only, no models)
RUN curl -fsSL https://ollama.com/install.sh | sh

# Copy pre-downloaded and compressed models
COPY --from=ollama-cache /ollama-models.tar.gz /tmp/ollama-models.tar.gz

# Extract models to the correct location
RUN mkdir -p /root/.ollama && \
    cd /root/.ollama && \
    tar -xzf /tmp/ollama-models.tar.gz && \
    rm /tmp/ollama-models.tar.gz

# Copy the built binary and assets
COPY --from=builder /app/target/release/full-working-o1 /app/full-working-o1
COPY --from=builder /app/minimal_3d.html /app/minimal_3d.html
COPY --from=builder /app/static /app/static

# Create optimized startup script
RUN echo '#!/bin/bash' > /app/start.sh && \
    echo 'set -e' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo 'echo "🚀 Think AI with pre-cached Ollama starting..."' >> /app/start.sh && \
    echo 'echo "📊 Models already cached - no download needed!"' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Start Ollama with pre-cached models' >> /app/start.sh && \
    echo 'OLLAMA_HOST=0.0.0.0:11434 OLLAMA_MODELS=/root/.ollama/models ollama serve &' >> /app/start.sh && \
    echo 'OLLAMA_PID=$!' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Quick startup check' >> /app/start.sh && \
    echo 'echo "⏳ Waiting for Ollama (should be fast with cached models)..."' >> /app/start.sh && \
    echo 'for i in {1..30}; do' >> /app/start.sh && \
    echo '    if curl -s http://localhost:11434/api/tags 2>/dev/null | grep -q "qwen2.5:1.5b"; then' >> /app/start.sh && \
    echo '        echo "✅ Ollama ready with Qwen 2.5 1.5B in $i seconds!"' >> /app/start.sh && \
    echo '        break' >> /app/start.sh && \
    echo '    fi' >> /app/start.sh && \
    echo '    sleep 1' >> /app/start.sh && \
    echo 'done' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Quick model test' >> /app/start.sh && \
    echo 'echo "🧪 Quick model test..."' >> /app/start.sh && \
    echo 'TEST=$(echo '\''{"model": "qwen2.5:1.5b", "prompt": "hi", "stream": false}'\'' | curl -s -X POST http://localhost:11434/api/generate -H "Content-Type: application/json" -d @- 2>/dev/null || echo "{}")' >> /app/start.sh && \
    echo 'if echo "$TEST" | grep -q "response"; then' >> /app/start.sh && \
    echo '    echo "✅ Model responding!"' >> /app/start.sh && \
    echo 'fi' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Start main app' >> /app/start.sh && \
    echo 'echo "🌐 Starting Think AI on port ${PORT:-8080}..."' >> /app/start.sh && \
    echo 'cd /app && exec ./full-working-o1' >> /app/start.sh && \
    chmod +x /app/start.sh

WORKDIR /app
EXPOSE 8080

# Use shell form to ensure environment variables work
CMD ["/bin/bash", "/app/start.sh"]