cache=/root/.think-ai-cache/npm
cache-min=9999999
prefer-offline=true
audit=false
fund=false
update-notifier=false
progress=false
loglevel=error
package-lock=true
save-exact=true
fetch-retries=2
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000
save-prefix=
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
