{
  "name": "think-ai-cli",
  "version": "0.2.0",
  "description": "AI-powered coding assistant with vector search capabilities",
  "main": "dist/index.js",
  "bin": {
    "think": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "cli",
    "code-assistant",
    "vector-search",
    "machine-learning"
  ],
  "author": "Think AI",
  "license": "MIT",
  "dependencies": {
    "@xenova/transformers": "^2.6.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "inquirer": "^9.2.0",
    "ora": "^7.0.1",
    "vectordb": "^0.4.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/champi-dev/think_ai.git"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
