# Use our pre-built full system image
FROM devsarmico/think-ai:full-system-latest

# The image already has everything set up
# Just ensure the working directory and user are correct
WORKDIR /app
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

EXPOSE 8080

# Run the FULL system
CMD ["python3", "process_manager.py"]