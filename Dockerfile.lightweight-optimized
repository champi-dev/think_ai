# Think AI Lightweight Docker Image - Production Optimized
# Ultra-minimal image with O(1) dependencies only

FROM python:3.11-slim AS builder

# Install only build essentials for wheel creation
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy requirements and build wheels
COPY requirements.lightweight.txt .
RUN pip wheel --no-cache-dir --wheel-dir /wheels -r requirements.lightweight.txt

# Final stage - minimal runtime
FROM python:3.11-slim

# Create non-root user
RUN groupadd -r appuser && useradd -r -g appuser appuser

# Install only runtime essentials
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Set environment for lightweight mode
ENV THINK_AI_LIGHTWEIGHT=true \
    THINK_AI_COLOMBIAN=true \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/home/appuser/.local/bin:$PATH"

# Copy wheels from builder
COPY --from=builder /wheels /wheels

# Install wheels as appuser
USER appuser
WORKDIR /home/appuser

# Copy requirements file from builder
COPY --from=builder /build/requirements.lightweight.txt /tmp/

# Install dependencies
RUN pip install --user --no-cache-dir --no-index --find-links=/wheels uvicorn==0.27.0 typing-extensions==4.9.0 python-multipart==0.0.6

# Copy application code
COPY --chown=appuser:appuser think_ai ./think_ai
COPY --chown=appuser:appuser railway_startup.py ./
COPY --chown=appuser:appuser think_ai_full.py ./
COPY --chown=appuser:appuser start_v3.py ./

# Create necessary directories
RUN mkdir -p data logs models

# Add Railway labels
LABEL railway.cache=true
LABEL railway.cache.key="think-ai-lightweight-v1"
LABEL org.opencontainers.image.title="Think AI Lightweight"
LABEL org.opencontainers.image.description="Ultra-lightweight Think AI with O(1) dependencies"
LABEL org.opencontainers.image.version="1.0.0"
LABEL org.opencontainers.image.authors="Think AI Team"

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:${PORT:-8080}/health || exit 1

# Expose port (Railway provides PORT env var)
EXPOSE ${PORT:-8080}

# Start with lightweight runtime
CMD ["python", "railway_startup.py"]