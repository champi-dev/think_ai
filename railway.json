{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.railway-prebuilt"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "startCommand": "python3 process_manager.py",
    "environmentVariables": {
      "PYTHONUNBUFFERED": "1",
      "THINK_AI_COLOMBIAN": "true",
      "THINK_AI_USE_LIGHTWEIGHT": "false",
      "THINK_AI_MINIMAL_INIT": "false",
      "THINK_AI_MODEL": "Qwen/Qwen2.5-0.5B-Instruct",
      "TRANSFORMERS_CACHE": "/app/models",
      "HF_HOME": "/app/models",
      "TORCH_HOME": "/app/models",
      "RAILWAY_ENVIRONMENT": "true",
      "PORT": "${{PORT}}"
    }
  }
}
