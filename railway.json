{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 60,
    "restartPolicyMaxRetries": 10,
    "startCommand": "python railway_server.py"
  },
  "environments": {
    "production": {
      "build": {
        "buildCommand": "echo 'Using Nixpacks build'"
      }
    }
  }
}
