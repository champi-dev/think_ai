{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile.railway"
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyMaxRetries": 10
  },
  "environments": {
    "production": {
      "build": {
        "buildCommand": "echo 'Using optimized Dockerfile'"
      },
      "deploy": {
        "startCommand": "/usr/local/bin/think-ai --host 0.0.0.0 --port 8080"
      }
    }
  }
}
