# Copy this file to .env and fill in your actual tokens
# Never commit .env to version control!

# npm deployment token
NPM_TOKEN=your_npm_auth_token_here

# PyPI deployment token
PYPI_TOKEN=your_pypi_token_here

# Google Cloud Platform API key (if needed)
GCP_API_KEY=your_gcp_api_key_here

# Gemini API Configuration (Optional - Fallback for Qwen/Ollama)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace API Configuration (Optional - only needed for cloud models)
# Get your token from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# or
HF_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Model Configuration
# For local Ollama: qwen2:1.5b
# For HuggingFace cloud: Qwen/Qwen2.5-1.5B-Instruct
MODEL_ID=qwen2:1.5b

# Ollama Configuration (for local models)
OLLAMA_HOST=http://localhost:11434

# Audio Service Configuration (Optional)
# Deepgram for speech-to-text: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# ElevenLabs for text-to-speech: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Audio cache directory
AUDIO_CACHE_DIR=./audio_cache

# Think AI Configuration
THINK_AI_PORT=8080
THINK_AI_LOG_LEVEL=info

# Twilio Configuration (for WhatsApp integration)
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO_NUMBER=your_whatsapp_number_here

# Security
JWT_SECRET=change-this-secret-key-in-production
