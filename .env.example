# Think AI Configuration Example
# Copy this file to .env and update with your values

# ScyllaDB Configuration
SCYLLA_HOSTS=localhost
SCYLLA_PORT=9042
SCYLLA_KEYSPACE=think_ai
SCYLLA_USERNAME=
SCYLLA_PASSWORD=
SCYLLA_REPLICATION_FACTOR=3
SCYLLA_CONSISTENCY_LEVEL=QUORUM

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CLUSTER_MODE=false

# Vector Database Configuration
VECTOR_DB_PROVIDER=milvus  # Options: milvus, qdrant
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=19530
VECTOR_DB_COLLECTION=think_ai_vectors

# Model Configuration
MODEL_NAME=EleutherAI/pythia-2.8b
MODEL_DEVICE=cpu  # Options: cpu, cuda, mps
MODEL_QUANTIZATION=int4
MODEL_MAX_TOKENS=2048

# UI Configuration
UI_THEME=dark
UI_LOG_LEVEL=INFO

# Consciousness Configuration
ENABLE_COMPASSION_METRICS=true
ETHICAL_FRAMEWORK=constitutional_ai
LOVE_BASED_DESIGN=true

# General Settings
DEBUG=false
LOG_LEVEL=INFO