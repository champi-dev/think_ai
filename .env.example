# Think AI Environment Variables

# HuggingFace Token (required for Qwen model)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Optional: Anthropic API Key (for Claude enhancement)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional: Database passwords (defaults work for local development)
NEO4J_PASSWORD=thinkaipass
SCYLLA_PASSWORD=cassandra
