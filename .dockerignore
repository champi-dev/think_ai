# Elite .dockerignore for O(1) build performance

# Version control
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.log
.mypy_cache
.hypothesis

# Virtual environments
venv/
env/
ENV/
.venv

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.next/
out/
dist/
webapp/node_modules/
webapp/.next/
webapp/out/
webapp/dist/

# IDE
.idea
.vscode
*.swp
*.swo
*~
.project
.pydevproject

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Project specific
*.db
*.sqlite
*.sqlite3
logs/
tmp/
temp/
THINK_AI_DEPLOYMENT_*/
deployment_test_*/
test_venv/

# Documentation
docs/_build/
site/

# Secrets
.env
.env.*
!.env.example
!.env.production

# Test files
test_*.py
!tests/test_*.py
*.test.js
*.spec.js

# O(1) Build Optimizations - Exclude heavy directories
# webapp/ - NEEDED for build, don't exclude!
examples/
notebooks/
scripts/
benchmarks/
plugins/
servers/
deployment/
generated_code/

# Exclude all cache and build directories
.o1-ultra-cache/
.o1-demo-cache/
railway-cache/
O1_*
o1_*
*.tar.xz
*.whl

# Build artifacts
build/
*.egg-info/
.eggs/
wheels/
*.egg

# Keep deployment files
!deployment/