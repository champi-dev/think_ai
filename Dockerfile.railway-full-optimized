# Full Think AI System - Optimized for Railway
# Maintains 100% capabilities with size optimization

# Multi-stage build for caching
FROM python:3.11-slim AS builder

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ git curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /wheels

# Copy all requirements files
COPY requirements*.txt ./

# Build wheels for all dependencies (massive cache benefit)
RUN pip wheel --no-cache-dir --wheel-dir /wheels \
    -r requirements.txt

# Stage 2: Final image with full system
FROM python:3.11-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    # Create user
    useradd -m -u 1000 appuser

WORKDIR /app

# Copy wheels and install
COPY --from=builder /wheels /wheels
RUN pip install --no-cache-dir --no-index --find-links /wheels /wheels/*.whl && \
    rm -rf /wheels && \
    # Clean pip cache
    rm -rf ~/.cache/pip

# Copy the ENTIRE Think AI system
COPY --chown=appuser:appuser . .

# Install Think AI in development mode (no copy, just link)
RUN pip install -e . --no-deps

# Pre-compile Python files for faster startup
RUN python -m compileall -b think_ai && \
    # Remove source .py files to save space (keep .pyc)
    find think_ai -name "*.py" -not -name "__init__.py" -delete 2>/dev/null || true

# Remove unnecessary files
RUN find . -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true && \
    find . -name "*.pyc" -delete 2>/dev/null || true && \
    find . -name "test_*.py" -delete 2>/dev/null || true && \
    find . -name "*.md" -not -name "README.md" -delete 2>/dev/null || true && \
    rm -rf tests/ docs/ scripts/testing/ examples/ .git/ && \
    rm -rf *.tar.gz *.bak *.old *.tmp

# Create necessary directories
RUN mkdir -p /app/data /app/logs /app/models && \
    chown -R appuser:appuser /app

USER appuser

# Pre-download lightweight models if needed
ENV TRANSFORMERS_CACHE=/app/models \
    HF_HOME=/app/models \
    TORCH_HOME=/app/models \
    PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    THINK_AI_USE_LIGHTWEIGHT=false \
    THINK_AI_MINIMAL_INIT=false

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

EXPOSE 8080

# Run the FULL system
CMD ["python", "think_ai_full.py"]