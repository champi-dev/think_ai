# Simple Dockerfile for Think AI - Fast startup without health checks
FROM rust:1.82 as builder

WORKDIR /app
COPY . .
RUN cargo build --release --bin full-working-o1

# Simple runtime
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/full-working-o1 /app/full-working-o1
COPY --from=builder /app/minimal_3d.html /app/minimal_3d.html
COPY --from=builder /app/static /app/static

WORKDIR /app
EXPOSE 8080

# Direct startup - no Ollama, just the app
CMD ["./full-working-o1"]