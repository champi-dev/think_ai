# Working Dockerfile with proper Ollama startup
FROM rust:1.82 as builder

WORKDIR /app
COPY . .
RUN cargo build --release --bin full-working-o1

# Runtime with Ollama
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Copy app files
COPY --from=builder /app/target/release/full-working-o1 /app/full-working-o1
COPY --from=builder /app/minimal_3d.html /app/minimal_3d.html
COPY --from=builder /app/static /app/static

# Create a robust startup script that waits for Ollama
RUN echo '#!/bin/bash' > /app/start.sh && \
    echo 'set -e' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Start Ollama in background' >> /app/start.sh && \
    echo 'echo "🚀 Starting Ollama..."' >> /app/start.sh && \
    echo 'ollama serve &' >> /app/start.sh && \
    echo 'OLLAMA_PID=$!' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Wait for Ollama to be ready' >> /app/start.sh && \
    echo 'echo "⏳ Waiting for Ollama to be ready..."' >> /app/start.sh && \
    echo 'while ! curl -s http://localhost:11434/api/tags >/dev/null 2>&1; do' >> /app/start.sh && \
    echo '    echo "  Still waiting for Ollama..."' >> /app/start.sh && \
    echo '    sleep 2' >> /app/start.sh && \
    echo 'done' >> /app/start.sh && \
    echo 'echo "✅ Ollama is ready!"' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Pull Qwen model' >> /app/start.sh && \
    echo 'echo "📥 Pulling Qwen model..."' >> /app/start.sh && \
    echo 'ollama pull qwen2.5:1.5b || echo "⚠️ Model pull failed, continuing anyway"' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Wait a bit more to ensure model is loaded' >> /app/start.sh && \
    echo 'sleep 10' >> /app/start.sh && \
    echo '' >> /app/start.sh && \
    echo '# Now start the main app' >> /app/start.sh && \
    echo 'echo "🌐 Starting Think AI..."' >> /app/start.sh && \
    echo 'cd /app && exec ./full-working-o1' >> /app/start.sh && \
    chmod +x /app/start.sh

WORKDIR /app
EXPOSE 8080

# Increase startup timeout
ENV RAILWAY_HEALTHCHECK_TIMEOUT_SEC=600

CMD ["/app/start.sh"]