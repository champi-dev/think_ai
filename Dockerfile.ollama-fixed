# Railway-optimized Dockerfile for Think AI with GUARANTEED Ollama availability
FROM rust:1.82 as builder

RUN apt-get update && apt-get install -y ca-certificates libssl-dev pkg-config && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY . .
RUN cargo build --release --bin full-working-o1

# Runtime stage with Ollama
FROM ubuntu:22.04

# Install dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    htop \
    procps \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install latest Ollama using official installer
RUN curl -fsSL https://ollama.com/install.sh | sh

# Copy the built binary and assets
COPY --from=builder /app/target/release/full-working-o1 /app/full-working-o1
COPY --from=builder /app/minimal_3d.html /app/minimal_3d.html
COPY --from=builder /app/static /app/static

# Create enhanced startup script that ENSURES Ollama is running
RUN cat > /app/start.sh << 'EOF'
#!/bin/bash
set -e

echo "🚀 Think AI with Ollama Starting..."
echo "📊 System Information:"
echo "  - Memory: $(free -h | grep Mem | awk '{print $2}')"
echo "  - CPU: $(nproc) cores"
echo "  - Disk: $(df -h / | tail -1 | awk '{print $4}') free"
echo "  - Port: ${PORT:-8080}"

# Create necessary directories
mkdir -p /root/.ollama/models

# Function to ensure Ollama is running
ensure_ollama_running() {
    if ! pgrep -x "ollama" > /dev/null; then
        echo "🔧 Starting Ollama server..."
        OLLAMA_HOST=0.0.0.0:11434 \
        OLLAMA_MODELS=/root/.ollama/models \
        OLLAMA_KEEP_ALIVE=24h \
        ollama serve > /tmp/ollama.log 2>&1 &
        OLLAMA_PID=$!
        
        # Wait for Ollama to be ready
        echo "⏳ Waiting for Ollama to start..."
        for i in {1..120}; do
            if curl -s http://localhost:11434/api/tags >/dev/null 2>&1; then
                echo "✅ Ollama started successfully!"
                return 0
            fi
            
            if [ $((i % 10)) -eq 0 ]; then
                echo "  Still waiting... ($i/120)"
            fi
            
            # Check if process died
            if ! kill -0 $OLLAMA_PID 2>/dev/null; then
                echo "❌ Ollama process died. Retrying..."
                return 1
            fi
            
            sleep 1
        done
        
        echo "❌ Ollama failed to start within timeout"
        return 1
    else
        echo "✅ Ollama is already running"
        return 0
    fi
}

# Function to ensure Qwen model is available
ensure_qwen_model() {
    echo "🔍 Checking for Qwen 2.5 1.5B model..."
    
    # Check if model exists
    if ollama list 2>/dev/null | grep -q "qwen2.5:1.5b"; then
        echo "✅ Qwen model already available"
        return 0
    fi
    
    echo "📥 Pulling Qwen 2.5 1.5B model..."
    for attempt in {1..5}; do
        if ollama pull qwen2.5:1.5b; then
            echo "✅ Qwen model downloaded successfully!"
            
            # Test the model
            echo "🧪 Testing Qwen model..."
            TEST_RESPONSE=$(echo '{"model": "qwen2.5:1.5b", "prompt": "Say hello", "stream": false}' | \
                           curl -s -X POST http://localhost:11434/api/generate \
                           -H "Content-Type: application/json" -d @- 2>/dev/null || echo "{}")
            
            if echo "$TEST_RESPONSE" | grep -q "response"; then
                echo "✅ Qwen model test successful!"
                return 0
            else
                echo "⚠️ Model test failed, retrying..."
            fi
        else
            echo "⚠️ Model pull failed (attempt $attempt/5), retrying in 10 seconds..."
            sleep 10
        fi
    done
    
    echo "❌ Failed to pull Qwen model after 5 attempts"
    return 1
}

# Main startup logic with retries
MAX_STARTUP_ATTEMPTS=3
STARTUP_ATTEMPT=0

while [ $STARTUP_ATTEMPT -lt $MAX_STARTUP_ATTEMPTS ]; do
    STARTUP_ATTEMPT=$((STARTUP_ATTEMPT + 1))
    echo ""
    echo "🚀 Startup attempt $STARTUP_ATTEMPT/$MAX_STARTUP_ATTEMPTS"
    
    # Ensure Ollama is running
    if ! ensure_ollama_running; then
        echo "⚠️ Ollama startup failed, retrying..."
        sleep 5
        continue
    fi
    
    # Ensure Qwen model is available
    if ! ensure_qwen_model; then
        echo "⚠️ Qwen model setup failed, retrying..."
        sleep 5
        continue
    fi
    
    # If we got here, everything is ready
    echo ""
    echo "✅ All systems ready!"
    echo "🌐 Starting Think AI server on port ${PORT:-8080}..."
    
    # Monitor Ollama in background
    (
        while true; do
            sleep 30
            if ! pgrep -x "ollama" > /dev/null; then
                echo "⚠️ Ollama process died, restarting..."
                ensure_ollama_running
                ensure_qwen_model
            fi
        done
    ) &
    
    # Start the main application
    cd /app && exec ./full-working-o1
done

# If we get here, startup failed
echo "❌ Failed to start after $MAX_STARTUP_ATTEMPTS attempts"
echo "📋 Ollama logs:"
tail -100 /tmp/ollama.log 2>/dev/null || echo "No logs available"
exit 1
EOF

RUN chmod +x /app/start.sh

WORKDIR /app
EXPOSE 8080

# Health check to ensure Ollama is running
HEALTHCHECK --interval=30s --timeout=10s --start-period=5m --retries=3 \
    CMD curl -f http://localhost:11434/api/tags && curl -f http://localhost:8080/health || exit 1

# Use exec form for better signal handling
ENTRYPOINT ["/bin/bash", "-c", "/app/start.sh"]